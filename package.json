{
  "name": "root",
  "private": true,
  "engines": {
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -F app-react dev",
    "build": "pnpm -F rc-marked-input run build",
    "build:all": "pnpm -r run build",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:fix:suggest": "oxlint . --fix-suggestions",
    "lint:fix:danger": "oxlint . --fix-dangerously",
    "format": "prettier . --check",
    "clean:git": "git clean -xdf",
    "clean:git:dry": "git clean -xdn",
    "format:write": "prettier . --write",
    "storybook:dev": "pnpm -F sb run dev",
    "storybook:build": "pnpm -F sb run build",
    "test": "pnpm -F tests run test",
    "test:ui": "pnpm -F tests run test:ui",
    "test:watch": "pnpm -F tests run test:watch",
    "test:integration": "pnpm -F tests run test:integration",
    "coverage": "pnpm -F tests run coverage",
    "preinstall": "npx only-allow pnpm",
    "publish": "pnpm -F rc-marked-input run publish"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.52.13",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "oxlint": "^1.16.0",
    "prettier": "3.6.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.6",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nowely/marked-input.git"
  },
  "type": "module"
}
