{
  "name": "marked-input",
  "private": true,
  "version": "3.1.0",
  "description": "React component for combine editable text with any component using annotated text",
  "license": "MIT",
  "author": "Ruslan Ilyin",
  "scripts": {
    "dev": "vite tests/e2e/app -c vite.config.ts --open",
    "build": "vite build && tsc && node prepack.js",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:fix:suggest": "oxlint . --fix-suggestions",
    "lint:fix:danger": "oxlint . --fix-dangerously",
    "storybook:dev": "npm run start -w storybook",
    "storybook:build": "npm run build -w storybook",
    "test": "npm run test -w tests",
    "test:ui": "npm run test:ui -w tests",
    "test:watch": "npm run test:watch -w tests",
    "test:integration": "npm run test:integration -w tests",
    "coverage": "npm run coverage -w tests"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.52.8",
    "@types/react": "^18.3.23",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "oxlint": "^1.6.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Nowely/marked-input.git"
  },
  "type": "module",
  "types": "./index.d.ts",
  "module": "./index.js",
  "main": "./index.umd.cjs",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.umd.cjs"
    }
  },
  "keywords": [
    "react",
    "react-component",
    "component",
    "mention",
    "markup",
    "marked-input",
    "highlight",
    "input"
  ],
  "workspaces": [
    "lib",
    "storybook",
    "tests"
  ]
}
