{
  "name": "@markput/monorepo",
  "version": "0.12.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -F @markput/storybook run dev",
    "dev:react:app": "pnpm -F @markput/react-app dev",
    "dev:vue:app": "pnpm -F @markput/vue-app dev",
    "dev:sb:react": "pnpm -F @markput/storybook run dev:react",
    "dev:sb:vue": "pnpm -F @markput/storybook run dev:vue",
    "dev:website": "pnpm -F @markput/website run dev",
    "build": "pnpm -r run build",
    "build:react": "pnpm -F @markput/react run build",
    "build:react:sb": "pnpm -F @markput/storybook run build:react",
    "build:vue": "pnpm -F @markput/vue run build",
    "build:vue:sb": "pnpm -F @markput/storybook run build:vue",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:related": "vitest run --changed",
    "bench": "vitest bench --run",
    "lint": "oxlint . --fix",
    "lint:check": "oxlint .",
    "lint:fix:suggest": "oxlint . --fix-suggestions",
    "lint:fix:danger": "oxlint . --fix-dangerously",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "pnpm -r run typecheck",
    "clean": "git clean -xdf",
    "clean:dry": "git clean -xdn",
    "preinstall": "npx only-allow pnpm",
    "publish": "pnpm -F @markput/react run publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.0",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "pnpm run lint",
      "pnpm run format"
    ],
    "*.{json,css,html}": [
      "pnpm run format"
    ]
  },
  "engines": {
    "pnpm": ">=9"
  }
}
