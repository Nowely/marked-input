{
  "name": "rc-marked-input",
  "version": "3.1.0",
  "description": "React component for combine editable text with any component using annotated text",
  "license": "MIT",
  "author": "Ruslan Ilyin",
  "scripts": {
    "build": "vite build && tsc && node prepack.js",
    "publish": "pnpm publish dist --no-git-checks --json"
  },
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "type": "module",
  "module": "./index.js",
