- </span></span></span><span><span><span><span><span><span contenteditable="false">Italic text</span></span></span></span></span></span><span><span><span contenteditable="false"> and </span></span></span><span><span><span><span><span><span contenteditable="false">emphasis</span></span></span></span></span></span><span><span><span contenteditable="false"> support
</span></span></span><span><span><span><span><span><span contenteditable="false"></span></span></span><span><span>Code snippets</span></span><span><span><span contenteditable="false"> and </span></span></span><span><span>code blocks</span></span><span><span><span contenteditable="false">
</span></span></span><span><span><span><span><span><span contenteditable="false"></span></span></span><span><span>Strikethrough</span></span><span><span><span contenteditable="false"> for deleted content
</span></span></span><span><span><span><span><span><span contenteditable="false">Links like </span></span></span><span><span>GitHub</span></span><span><span><span contenteditable="false"></span></span></span></span></span></span><span><span><span contenteditable="false"></span></span></span><span><span><span><span><span><span contenteditable="false">Example</span></span></span></span></span></span><span><span><span contenteditable="false">Here's how to use it:</span></span></span></span></span></span><span><span><span contenteditable="false"></span></span></span><span><span>const parser = new ParserV2(['**__value__**', '*__value__*'])
