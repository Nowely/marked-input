exports[`Component: stories > Nested stories > Story ComplexHtmlDocument 1`] = `
"<div><button>Preview</button><button>Write</button></div><div><span contenteditable="false"></span><article><span>
</span><header><span>
</span><h1><span>Understanding </span><strong><span>Nested HTML</span></strong><span> Structures</span></h1><span>
</span><p><span></span><small><span>Published on </span><time><span>November 13, 2025</span></time><span></span></small><span></span></p><span>
</span></header><span>

</span><section><span>
</span><h2><span>Introduction</span></h2><span>
</span><p><span>This is a </span><em><span>comprehensive example</span></em><span> of </span><strong><span>nested HTML tags</span></strong><span> working together. The </span><code><span>MarkedInput</span></code><span> library can parse and render </span><mark><span>complex HTML structures</span></mark><span> with multiple levels of nesting.</span></p><span>

</span><blockquote><span>
</span><p><span>HTML nesting allows us to create </span><strong><span>rich, semantic documents</span></strong><span> that are both </span><em><span>readable</span></em><span> and </span><u><span>well-structured</span></u><span>.</span></p><span>
</span></blockquote><span>
</span></section><span>

</span><section><span>
</span><h2><span>Key Features</span></h2><span>
</span><ul><span>
</span><li><span></span><strong><span>Bold text</span></strong><span> using </span><code><span>&amp;lt;strong&amp;gt;</span></code><span> or </span><code><span>&amp;lt;b&amp;gt;</span></code><span> tags</span></li><span>
</span><li><span></span><em><span>Italic text</span></em><span> with </span><code><span>&amp;lt;em&amp;gt;</span></code><span> or </span><code><span>&amp;lt;i&amp;gt;</span></code><span> tags</span></li><span>
</span><li><span></span><u><span>Underlined content</span></u><span> for emphasis</span></li><span>
</span><li><span></span><mark><span>Highlighted text</span></mark><span> to draw attention</span></li><span>
</span><li><span></span><del><span>Strikethrough</span></del><span> for deleted content</span></li><span>
</span><li><span></span><code><span>Inline code</span></code><span> snippets</span></li><span>
</span></ul><span>
</span></section><span>

</span><section><span>
</span><h2><span>Advanced Examples</span></h2><span>
</span><h3><span>Mathematical Notation</span></h3><span>
</span><p><span>The formula for water is H</span><sub><span>2</span></sub><span>O, and Einstein's famous equation is E=mc</span><sup><span>2</span></sup><span>.</span></p><span>

</span><h3><span>Code Blocks</span></h3><span>
</span><pre><span></span><code><span>function parseHTML(input) {
  return parser.parse(input);
}</span></code><span></span></pre><span>

</span><h3><span>Nested Lists</span></h3><span>
</span><ol><span>
</span><li><span>First level item
</span><ul><span>
</span><li><span>Second level </span><strong><span>nested</span></strong><span> item</span></li><span>
</span><li><span>Another nested item with </span><em><span>emphasis</span></em><span></span></li><span>
</span></ul><span>
</span></li><span>
</span><li><span>Another first level item</span></li><span>
</span></ol><span>
</span></section><span>

</span><section><span>
</span><h2><span>Complex Nesting</span></h2><span>
</span><div><span>
</span><p><span>Here's a </span><strong><span>complex example</span></strong><span> with </span><em><span>multiple </span><u><span>nested </span><mark><span>tags</span></mark><span></span></u><span> inside</span></em><span> each other.</span></p><span>
</span><p><span>You can even have </span><code><span>code with </span><strong><span>bold</span></strong><span> inside</span></code><span> or </span><mark><span>highlighted </span><em><span>italic </span><u><span>underlined</span></u><span></span></em><span> text</span></mark><span>.</span></p><span>
</span></div><span>
</span></section><span>

</span><footer><span>
</span><p><span></span><small><span>© 2025 MarkedInput Library. Built with </span><strong><span>React</span></strong><span> and </span><em><span>TypeScript</span></em><span>.</span></small><span></span></p><span>
</span></footer><span>
</span></article><span contenteditable="false"></span></div>"
`;

exports[`Component: stories > Nested stories > Story ComplexMarkdown 1`] = `
"<div><button>Preview</button><button>Write</button></div><div><span contenteditable="false"></span><span><span>Welcome to </span><span><span>Marked Input</span></span><span></span></span><span contenteditable="false">This is a </span><span><span>powerful</span></span><span contenteditable="false"> library for parsing </span><span><span>rich text</span></span><span contenteditable="false"> with </span><span><span>markdown</span></span><span contenteditable="false"> formatting.
You can use </span><span>inline code</span><span contenteditable="false"> snippets like </span><span>const parser = new ParserV2()</span><span contenteditable="false"> in your text.

</span><span><span>Features</span></span><span contenteditable="false">- </span><span><span>Bold text</span></span><span contenteditable="false"> with </span><span><span>strong emphasis</span></span><span contenteditable="false">
