exports[`Component: stories > Nested stories > Story ComplexHtmlDocument 1`] = `
"<div><button>Preview</button><button>Write</button></div><div><span contenteditable="false"></span><article><span contenteditable="false">
</span><header><span contenteditable="false">
</span><h1><span contenteditable="false">Understanding </span><strong><span contenteditable="false">Nested HTML</span></strong><span contenteditable="false"> Structures</span></h1><span contenteditable="false">
</span><p><span contenteditable="false"></span><small><span contenteditable="false">Published on </span><time><span contenteditable="false">November 13, 2025</span></time><span contenteditable="false"></span></small><span contenteditable="false"></span></p><span contenteditable="false">
</span></header><span contenteditable="false">

</span><section><span contenteditable="false">
</span><h2><span contenteditable="false">Introduction</span></h2><span contenteditable="false">
</span><p><span contenteditable="false">This is a </span><em><span contenteditable="false">comprehensive example</span></em><span contenteditable="false"> of </span><strong><span contenteditable="false">nested HTML tags</span></strong><span contenteditable="false"> working together. The </span><code><span contenteditable="false">MarkedInput</span></code><span contenteditable="false"> library can parse and render </span><mark><span contenteditable="false">complex HTML structures</span></mark><span contenteditable="false"> with multiple levels of nesting.</span></p><span contenteditable="false">

</span><blockquote><span contenteditable="false">
</span><p><span contenteditable="false">HTML nesting allows us to create </span><strong><span contenteditable="false">rich, semantic documents</span></strong><span contenteditable="false"> that are both </span><em><span contenteditable="false">readable</span></em><span contenteditable="false"> and </span><u><span contenteditable="false">well-structured</span></u><span contenteditable="false">.</span></p><span contenteditable="false">
</span></blockquote><span contenteditable="false">
</span></section><span contenteditable="false">

</span><section><span contenteditable="false">
</span><h2><span contenteditable="false">Key Features</span></h2><span contenteditable="false">
</span><ul><span contenteditable="false">
</span><li><span contenteditable="false"></span><strong><span contenteditable="false">Bold text</span></strong><span contenteditable="false"> using </span><code><span contenteditable="false">&amp;lt;strong&amp;gt;</span></code><span contenteditable="false"> or </span><code><span contenteditable="false">&amp;lt;b&amp;gt;</span></code><span contenteditable="false"> tags</span></li><span contenteditable="false">
</span><li><span contenteditable="false"></span><em><span contenteditable="false">Italic text</span></em><span contenteditable="false"> with </span><code><span contenteditable="false">&amp;lt;em&amp;gt;</span></code><span contenteditable="false"> or </span><code><span contenteditable="false">&amp;lt;i&amp;gt;</span></code><span contenteditable="false"> tags</span></li><span contenteditable="false">
</span><li><span contenteditable="false"></span><u><span contenteditable="false">Underlined content</span></u><span contenteditable="false"> for emphasis</span></li><span contenteditable="false">
</span><li><span contenteditable="false"></span><mark><span contenteditable="false">Highlighted text</span></mark><span contenteditable="false"> to draw attention</span></li><span contenteditable="false">
</span><li><span contenteditable="false"></span><del><span contenteditable="false">Strikethrough</span></del><span contenteditable="false"> for deleted content</span></li><span contenteditable="false">
</span><li><span contenteditable="false"></span><code><span contenteditable="false">Inline code</span></code><span contenteditable="false"> snippets</span></li><span contenteditable="false">
</span></ul><span contenteditable="false">
</span></section><span contenteditable="false">

</span><section><span contenteditable="false">
</span><h2><span contenteditable="false">Advanced Examples</span></h2><span contenteditable="false">
</span><h3><span contenteditable="false">Mathematical Notation</span></h3><span contenteditable="false">
</span><p><span contenteditable="false">The formula for water is H</span><sub><span contenteditable="false">2</span></sub><span contenteditable="false">O, and Einstein's famous equation is E=mc</span><sup><span contenteditable="false">2</span></sup><span contenteditable="false">.</span></p><span contenteditable="false">

</span><h3><span contenteditable="false">Code Blocks</span></h3><span contenteditable="false">
</span><pre><span contenteditable="false"></span><code><span contenteditable="false">function parseHTML(input) {
  return parser.parse(input);
}</span></code><span contenteditable="false"></span></pre><span contenteditable="false">

</span><h3><span contenteditable="false">Nested Lists</span></h3><span contenteditable="false">
</span><ol><span contenteditable="false">
</span><li><span contenteditable="false">First level item
</span><ul><span contenteditable="false">
</span><li><span contenteditable="false">Second level </span><strong><span contenteditable="false">nested</span></strong><span contenteditable="false"> item</span></li><span contenteditable="false">
</span><li><span contenteditable="false">Another nested item with </span><em><span contenteditable="false">emphasis</span></em><span contenteditable="false"></span></li><span contenteditable="false">
</span></ul><span contenteditable="false">
</span></li><span contenteditable="false">
</span><li><span contenteditable="false">Another first level item</span></li><span contenteditable="false">
</span></ol><span contenteditable="false">
</span></section><span contenteditable="false">

</span><section><span contenteditable="false">
</span><h2><span contenteditable="false">Complex Nesting</span></h2><span contenteditable="false">
</span><div><span contenteditable="false">
</span><p><span contenteditable="false">Here's a </span><strong><span contenteditable="false">complex example</span></strong><span contenteditable="false"> with </span><em><span contenteditable="false">multiple </span><u><span contenteditable="false">nested </span><mark><span contenteditable="false">tags</span></mark><span contenteditable="false"></span></u><span contenteditable="false"> inside</span></em><span contenteditable="false"> each other.</span></p><span contenteditable="false">
</span><p><span contenteditable="false">You can even have </span><code><span contenteditable="false">code with </span><strong><span contenteditable="false">bold</span></strong><span contenteditable="false"> inside</span></code><span contenteditable="false"> or </span><mark><span contenteditable="false">highlighted </span><em><span contenteditable="false">italic </span><u><span contenteditable="false">underlined</span></u><span contenteditable="false"></span></em><span contenteditable="false"> text</span></mark><span contenteditable="false">.</span></p><span contenteditable="false">
</span></div><span contenteditable="false">
</span></section><span contenteditable="false">

</span><footer><span contenteditable="false">
</span><p><span contenteditable="false"></span><small><span contenteditable="false">© 2025 MarkedInput Library. Built with </span><strong><span contenteditable="false">React</span></strong><span contenteditable="false"> and </span><em><span contenteditable="false">TypeScript</span></em><span contenteditable="false">.</span></small><span contenteditable="false"></span></p><span contenteditable="false">
</span></footer><span contenteditable="false">
</span></article><span contenteditable="false"></span></div>"
`;

exports[`Component: stories > Nested stories > Story ComplexMarkdown 1`] = `
"<div><button>Preview</button><button>Write</button></div><div><span contenteditable="false"></span><span><span contenteditable="false">Welcome to </span><span><span contenteditable="false">Marked Input</span></span><span contenteditable="false"></span></span><span contenteditable="false">This is a </span><span><span contenteditable="false">powerful</span></span><span contenteditable="false"> library for parsing </span><span><span contenteditable="false">rich text</span></span><span contenteditable="false"> with </span><span><span contenteditable="false">markdown</span></span><span contenteditable="false"> formatting.
You can use </span><span>inline code</span><span contenteditable="false"> snippets like </span><span>const parser = new ParserV2()</span><span contenteditable="false"> in your text.

</span><span><span contenteditable="false">Features</span></span><span contenteditable="false">- </span><span><span contenteditable="false">Bold text</span></span><span contenteditable="false"> with </span><span><span contenteditable="false">strong emphasis</span></span><span contenteditable="false">
- </span><span><span contenteditable="false">Italic text</span></span><span contenteditable="false"> and </span><span><span contenteditable="false">emphasis</span></span><span contenteditable="false"> support
