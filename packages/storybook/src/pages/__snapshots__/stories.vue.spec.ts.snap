exports[`Component: stories > Nested stories > Story SimpleNesting 1`] = `"<div style="display: flex; gap: 16px; height: 100%;"><div style="flex: 3 1 0%; min-width: 0px;"><div><span contenteditable="true">This is </span><span style="font-style: italic;"><span>italic text with </span><span style="font-weight: bold;"><span>bold</span></span><span> inside</span></span><span contenteditable="true"> and more text.</span></div><!--v-if--></div><div style="flex: 1 1 0%; min-width: 0px;"><div style="font-size: 11px; font-weight: bold; color: rgb(102, 102, 102); margin-bottom: 4px; text-transform: uppercase;">Plain Value</div><pre style="padding: 8px; font-family: monospace; font-size: 14px; margin: 0px;">This is *italic text with **bold** inside* and more text.</pre></div></div>"`;

