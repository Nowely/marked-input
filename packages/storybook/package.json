{
  "name": "@markput/storybook",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:react": "cross-env FRAMEWORK=react storybook dev --port 6006 --no-open",
    "dev:vue": "cross-env FRAMEWORK=vue storybook dev --port 6007 --no-open",
    "dev": "concurrently \"pnpm run dev:react\" \"pnpm run dev:vue\"",
    "build:react": "cross-env FRAMEWORK=react storybook build -o ./dist-react",
    "build:vue": "cross-env FRAMEWORK=vue storybook build -o ./dist-vue",
    "build": "pnpm run build:react && pnpm run build:vue",
    "test:react": "vitest run --project react",
    "test:vue": "vitest run --project vue",
    "test": "pnpm run test:react && pnpm run test:vue",
    "test:update:react": "vitest run --project react --update",
    "test:update:vue": "vitest run --project vue --update",
    "test:update": "pnpm run test:update:react && pnpm run test:update:vue",
    "test:watch:react": "vitest --project react",
    "test:watch:vue": "vitest --project vue",
    "test:watch": "concurrently \"pnpm run test:watch:react\" \"pnpm run test:watch:vue\"",
    "test:ui:react": "vitest --ui --project react",
    "test:ui:vue": "vitest --ui --project vue",
    "coverage": "pnpm run test:react --coverage && pnpm run test:vue --coverage"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@faker-js/faker": "catalog:",
    "@markput/react": "workspace:*",
    "@markput/vue": "workspace:*",
    "@mui/material": "^7.3.7",
    "antd": "^6.3.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rsuite": "^6.1.2",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-links": "catalog:",
    "@storybook/cli": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@storybook/vue3-vite": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "playwright": "catalog:",
    "storybook": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "catalog:",
    "vitest-browser-vue": "catalog:"
  }
}
