{
  "name": "@markput/core",
  "type": "module",
  "module": "index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "import": "./index.ts"
    },
    "./styles.module.css": "./styles.module.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "build:watch": "vite build -w",
    "test": "pnpm -w exec vitest run --project core",
    "test:watch": "pnpm -w exec vitest --project core",
    "test:related": "pnpm -w exec vitest run --changed --project core",
    "test:ui": "pnpm -w exec vitest --ui --project core",
    "test:coverage": "pnpm -w exec vitest run --project core --coverage",
    "coverage": "pnpm -w exec vitest run --project core --coverage",
    "bench": "pnpm -w exec vitest bench --run --project core"
  },
  "devDependencies": {
    "@faker-js/faker": "catalog:",
    "csstype": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
