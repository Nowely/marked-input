{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "react",
    "react-perf",
    "vue",
    "oxc",
    "import",
    "jsdoc",
    "jsx-a11y",
    "node",
    "promise",
    "vitest"
  ],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "import/no-cycle": "error",
    "import/no-duplicates": "error",
    "import/no-extraneous-dependencies": "error",
    "import/no-unresolved": "error",
    "eslint/sort-imports": "allow",
    "eslint/sort-exports": "error",
    "eslint/no-unused-private-class-members": "error",
    "eslint/no-unused-vars": "error",
    "eslint/no-shadow": "off",
    "eslint/no-throw-literal": "warn",
    "eslint/no-await-in-loop": "off",
    "typescript/consistent-type-imports": "error",
    "typescript/consistent-type-exports": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-dynamic-delete": "warn",
    "typescript/no-unsafe-type-assertion": "error",
    "typescript/dot-notation": "warn",
    "typescript/no-unnecessary-type-parameters": "warn",
    "typescript/no-redundant-type-constituents": "off",
    "typescript/consistent-return": "off",
    "typescript/no-unnecessary-condition": "error",
    "typescript/switch-exhaustiveness-check": "warn",
    "typescript/prefer-optional-chain": "warn",
    "typescript/prefer-nullish-coalescing": "warn",
    "typescript/no-misused-promises": "warn",
    "typescript/no-unsafe-argument": "error",
    "typescript/no-unsafe-assignment": "off",
    "typescript/no-unsafe-call": "error",
    "typescript/no-unsafe-member-access": "error",
    "typescript/no-unsafe-return": "error",
    "unicorn/no-useless-spread": "warn",
    "unicorn/prefer-module": "warn",
    "unicorn/prefer-ternary": "warn",
    "unicorn/consistent-function-scoping": "off",
    "react/no-children-prop": "allow",
    "react/exhaustive-deps": "off",
    "react/react-in-jsx-scope": "off",
    "react-perf/jsx-no-new-object-as-prop": "off",
    "react-perf/jsx-no-new-function-as-prop": "off",
    "jsx_a11y/click-events-have-key-events": "off",
    "vitest/warn-todo": "off",
    "jest/valid-expect": "off",
    "jest/no-disabled-tests": "off",
    "react-perf/jsx-no-jsx-as-prop": "off",
    "react-perf/jsx-no-new-array-as-prop": "off",
    "import/no-unassigned-import": ["warn", {"allow": ["**/*.css"]}]
  },
  "overrides": [
    {
      "files": [
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.spec.react.tsx",
        "**/*.stories.ts",
        "**/*.stories.tsx",
        "**/*.stories.react.tsx",
        "**/*.bench.ts",
        "**/*.js"
      ],
      "rules": {
        "typescript/no-explicit-any": "off",
        "typescript/no-non-null-assertion": "off",
        "typescript/no-unsafe-argument": "off",
        "typescript/no-unsafe-assignment": "off",
        "typescript/no-unsafe-call": "off",
        "typescript/no-unsafe-member-access": "off",
        "typescript/no-unsafe-return": "off",
        "typescript/unbound-method": "off"
      }
    },
    {
      "files": ["**/*.vue"],
      "rules": {
        "eslint/no-unused-expressions": "off"
      }
    },
    {
      "files": ["**/vitest.setup*.ts"],
      "rules": {
        "typescript/no-unsafe-call": "off"
      }
    }
  ],
  "ignorePatterns": ["packages/website/**"],
  "settings": {
    "jsdoc": {
      "ignorePrivate": false,
      "ignoreInternal": false,
      "ignoreReplacesDocs": true,
      "overrideReplacesDocs": true,
      "augmentsExtendsReplacesDocs": false,
      "implementsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "tagNamePreference": {}
    }
  },
  "env": {
    "builtin": true
  },
  "options": {
    "typeAware": true,
    "typeCheck": false
  }
}
